[global]
workspace_dir=/opt/ad-stack
start_services=true

[cleanup]
enabled=true
backup_configs=true
remove_repo_dirs=false
remove_portainer_container=false
remove_portainer_volume=false
wipe_traffic_dir=false
docker_prune=false

[packages]
apt_packages=apparmor-utils apache2-utils curl git docker.io docker-compose-plugin tcpdump

[traffic]
enabled=true
directory=/traffic
interface=game
rotate_seconds=60
rotate_size_mb=100
file_pattern=dump-%m-%d-%H-%M-%S-%s.pcap
bpf_filter=port not 22

[git]
tulip_repo_url=https://github.com/gcammisa/tulip-auth.git
s4dfarm_repo_url=https://github.com/gcammisa/S4DFarm.git
pull_existing=true

[firegex]
enabled=true
install_url=https://pwnzer0tt1.it/firegex.sh

[portainer]
enabled=true
container_name=portainer
volume_name=portainer_data
image=portainer/portainer-ce:latest
restart_policy=always
host_http_port=8000
container_http_port=8000
host_https_port=9443
container_https_port=9443
extra_args=

[tulip]
enabled=true
repo_dir=tulip-auth
python_config_file=services/configurations.py
env_example_file=.env.example
env_file=.env
start_compose=true
compose_command=docker compose up --build -d
summary_vm_ip=10.60.9.1
summary_port=3001

[tulip.python]
vm_ip="10.60.9.1"
services=[{"ip": "10.60.9.1", "port": 8001, "name": "Service1"}, {"ip": "10.60.9.1", "port": 8002, "name": "Service2"}]

[tulip.env]
TRAFFIC_DIR_HOST=/traffic
TICK_LENGTH=120000

[tulip.auth]
username=attackdefense
password=ChangeMeNow

[s4dfarm]
enabled=true
repo_dir=S4DFarm
python_config_file=server/app/config.py
start_compose=true
compose_command=docker compose up --build -d
summary_port=5137

[s4dfarm.python]
SCOREBOARD_IP="10.10.0.1"
FLAG_SUBMIT_URL="http://10.10.0.1:8080/flags"
S4D_PASSWORD="passwordS4D"
TEAM_TOKEN="token1234"
NUMBER_OF_TEAMS=44
